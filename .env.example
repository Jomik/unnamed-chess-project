# WiFi credentials (required for ESP32 WiFi features)
WIFI_SSID=
WIFI_PASSWORD=

# Pre-cloned ESP-IDF path (workaround for macOS memory issue with recursive git clone)
# If embuild's clone fails on your machine, run `just setup-idf` and uncomment this:
# IDF_PATH=.embuild/espressif/esp-idf/v5.5.3

# Lichess AI integration (optional — falls back to embedded AI without token)
# Create a token with the correct scopes using this link:
# https://lichess.org/account/oauth/token/create?scopes[]=board:play&scopes[]=challenge:write&description=Chess+Board
LICHESS_API_TOKEN=
LICHESS_AI_LEVEL=4
LICHESS_CLOCK_LIMIT=10800
LICHESS_CLOCK_INCREMENT=180
